# Configurações do Supabase para manter seus dados originais
# Copie este arquivo para .env e preencha com seus dados do projeto Supabase

VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Chave da API do Gemini para o comando de voz
GEMINI_API_KEY=sua-chave-aqui
